# YAOQI Backend — env template
# Copy to `.env` and fill in real values.
# Stage 1 only reads APP_ENV / APP_VERSION / LOG_LEVEL / REQUEST_ID_HEADER.
# Other vars are pre-declared so Stage 2-4 can pick them up without touching this file.

# === Stage 1 必读 ===
APP_ENV=local                         # local | staging | production
APP_VERSION=0.1.0
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
REQUEST_ID_HEADER=X-Request-ID

# === Stage 2 起读取(数据层)===
APP_URL=http://localhost:8000
DATABASE_URL=postgresql+asyncpg://yq_app:CHANGEME@localhost:5432/yaoqi
DB_POOL_SIZE=5                        # 常驻连接数;阿里云 RDS PG16 默认 max_connections=2000,留余量
DB_MAX_OVERFLOW=5                     # 突发额外连接数;总并发 = pool_size + max_overflow
DB_POOL_TIMEOUT=30                    # 等连接超时(秒);超时直接抛 TimeoutError 避免请求堆积
DB_ECHO=false                         # SQLAlchemy SQL 日志;production 必关,本地排查打开
HEALTH_DB_TIMEOUT_SECONDS=2.0         # /health.db 探活超时;超过即标 degraded(K8s readiness 依赖)
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=                           # secrets.token_urlsafe(32) — never commit a real value

# === Stage 4 起读取(阿里云)===
ALIYUN_OSS_REGION=oss-cn-hangzhou
ALIYUN_OSS_BUCKET=yaoqi-staging
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=

ALIYUN_OCR_ACCESS_KEY_ID=
ALIYUN_OCR_ACCESS_KEY_SECRET=

ALIYUN_SMS_REGION=cn-hangzhou
ALIYUN_SMS_SIGN_NAME=曜齐
ALIYUN_SMS_TEMPLATE_LOGIN=SMS_xxxxxxxx
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=

# === Stage 4 起读取(Azure OpenAI 跨云)===
AOAI_ENDPOINT=https://yaoqi-aoai-hk.openai.azure.com/
AOAI_API_KEY=
AOAI_API_VERSION=2024-10-21
AOAI_DEPLOYMENT_REPORT=aoai-private-report
AOAI_DEPLOYMENT_OCR=aoai-deployment-ocr-correct
AOAI_DEPLOYMENT_IMAGE_SUMMARY=aoai-deployment-image-summary
AOAI_DEPLOYMENT_EMBEDDING=aoai-text-embedding-3-small

# === Mock 开关(production 全 false)===
MOCK_AUTH=false
MOCK_OSS=false
MOCK_OCR=false
MOCK_AI=false
SEED_MOCK_DATA=false

# === RAG(M4 默认关)===
RAG_RECALL_ENABLED=false
